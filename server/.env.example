# Runtime
NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgres://admin:admin@localhost:5432/bankdb

# Redis (caching, rate-limit store, idempotency, BullMQ) — Phase 4+
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth — Phase 3+ (min 16 chars)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h

# Paystack test keys — Phase 5+
PAYSTACK_SECRET_KEY=sk_test_xxx
