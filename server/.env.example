# Runtime
NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgres://admin:admin@localhost:5432/bankdb

# Redis (read caching + idempotency keys).
# Local dev uses the host/port below. For a managed/hosted Redis (e.g. Coolify),
# set REDIS_URL instead — it takes precedence and carries auth + db index + TLS:
#   REDIS_URL=redis://default:password@host:6379/0   (use rediss:// for TLS)
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS — comma-separated browser origins allowed to call the API.
# Unset reflects any origin (fine for local dev); set it in production.
# CORS_ORIGIN=https://your-client.example.com

# Auth — Phase 3+ (min 16 chars)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h

# Paystack test keys — Phase 5+
PAYSTACK_SECRET_KEY=sk_test_xxx
